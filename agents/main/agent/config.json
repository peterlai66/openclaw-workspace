{
  "name": "main",
  "permissions": {
    "allow_execute": true,
    "allow_switch_model": false,
    "admin_access": true
  },
  "execution": {
    "mode": "agent",
    "auto_run": true,
    "max_steps": 10,
    "timeout_ms": 60000
  },
  "memory": {
    "enabled": true,
    "max_history": 50
  },
  "tools": {
    "auto_discover": true,
    "allowed": ["*"],
    "blocked": []
  },
  "safety": {
    "confirm_before_execute": false
  }
}
